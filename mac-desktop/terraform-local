#!/usr/bin/env bash
set -euo pipefail

cd "$(dirname "$0")"

export TF_CLI_CONFIG_FILE="$PWD/terraform.rc"

if ! command -v terraform >/dev/null 2>&1; then
  echo "terraform is not available in PATH" >&2
  exit 127
fi

if [ ! -x /Users/dongho/go/bin/terraform-provider-host ]; then
  mkdir -p /Users/dongho/go/bin

  if command -v go >/dev/null 2>&1; then
    (cd /Users/dongho/projects/terraform-provider-host && go install)
  elif command -v docker >/dev/null 2>&1; then
    case "$(uname -m)" in
      arm64 | aarch64)
        host_arch="arm64"
        ;;
      x86_64 | amd64)
        host_arch="amd64"
        ;;
      *)
        echo "unsupported architecture: $(uname -m)" >&2
        exit 127
        ;;
    esac

    docker run --rm \
      -e CGO_ENABLED=0 \
      -e GOOS="$(uname -s | tr '[:upper:]' '[:lower:]')" \
      -e GOARCH="$host_arch" \
      -v /Users/dongho/projects/terraform-provider-host:/workspace \
      -v /Users/dongho/go/bin:/output \
      -w /workspace \
      golang:1.25 \
      go build -o /output/terraform-provider-host .
  else
    echo "go or docker is required to build /Users/dongho/go/bin/terraform-provider-host" >&2
    exit 127
  fi
fi

exec terraform "$@"
