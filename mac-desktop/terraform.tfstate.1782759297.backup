    {
      "mode": "managed",
      "type": "host_file",
      "name": "zshrc",
      "provider": "provider[\"registry.terraform.io/dongho-jung/host\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "block": {
              "alias": {
                "content": "alias ga='git add' gc='git commit -v' gl='git pull' gp='git push' gg='lazygit' gst='git status' gco='git checkout'\nalias gr='git restore' grs='git restore --staged' gd='git diff' gds='git diff --staged' glog='git log --all --decorate --oneline --graph'\nalias y='pbcopy' p='pbpaste'\nalias rr='source ~/.zshrc'\nalias rm='echo \"rm is disabled. use `trash` command instead.\"'\nalias -g ...='../..'\nalias -g ....='../../..'",
                "name": "alias",
                "path": "~/.zshrc.preview"
              },
              "environment": {
                "content": "export LESSHISTFILE=/dev/null\nexport WORDCHARS=\"\"\nexport LANG=\"en_US.UTF-8\"\nexport LC_ALL=\"en_US.UTF-8\"\nexport HISTFILE=\"$HOME/projects/shell-history/mac-desktop\"\nexport HISTSIZE=1000000000\nexport SAVEHIST=1000000000",
                "name": "environment",
                "path": "~/.zshrc.preview"
              },
              "functions": {
                "content": "tmp() {\n  TMP=~/tmp/$(date +%F)\n  if [ \"$#\" -gt 0 ]; then\n    TMP=\"${TMP}-$(echo \"$@\" | tr ' ' '-')\"\n  fi\n  mkdir -p \"$TMP\"\n  cd \"$TMP\"\n}",
                "name": "functions",
                "path": "~/.zshrc.preview"
              },
              "integrations": {
                "content": null,
                "name": "integrations",
                "path": "~/.zshrc.preview"
              },
              "keybindings": {
                "content": "bindkey -e\nbindkey '^[[1;3C' forward-word\nbindkey '^[[1;3D' backward-word\nbindkey '^[[1;5C' end-of-line\nbindkey '^[[1;5D' beginning-of-line\nbindkey '^[b' beginning-of-line\nbindkey '^[f' end-of-line",
                "name": "keybindings",
                "path": "~/.zshrc.preview"
              },
              "options": {
                "content": "setopt append_history\nsetopt autopushd\nsetopt extended_glob\nsetopt hist_find_no_dups\nsetopt hist_ignore_all_dups\nsetopt hist_ignore_space\nsetopt hist_reduce_blanks\nsetopt hist_save_no_dups\nsetopt inc_append_history\nsetopt interactive_comments\nsetopt share_history",
                "name": "options",
                "path": "~/.zshrc.preview"
              },
              "path": {
                "content": null,
                "name": "path",
                "path": "~/.zshrc.preview"
              },
              "sources": {
                "content": null,
                "name": "sources",
                "path": "~/.zshrc.preview"
              }
            },
            "id": "~/.zshrc.preview",
            "path": "~/.zshrc.preview"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0
        }
      ]
    },
