  "resources": [
    {
      "mode": "managed",
      "type": "host_file",
      "name": "zshrc",
      "provider": "provider[\"registry.terraform.io/dongho-jung/host\"]",
      "instances": [
        {
          "schema_version": 0,
          "attributes": {
            "block": null,
            "content": "export EDITOR=nvim\nexport FZF_CTRL_R_OPTS=\"--scheme=history\"\nexport LESSHISTFILE=/dev/null\nexport WORDCHARS=\"\"\nexport LANG=\"en_US.UTF-8\"\nexport LC_ALL=\"en_US.UTF-8\"\nexport HISTFILE=\"$HOME/projects/shell-history/mac-desktop\"\nexport HISTSIZE=1000000000\nexport SAVEHIST=1000000000\n\nexport PATH=\"$PATH:$HOME/Library/Android/sdk/platform-tools/\"\nexport PATH=\"$PATH:$HOME/.cargo/bin\"\n\nalias c='IS_DEMO=1 claude --ide --chrome --allow-dangerously-skip-permissions --effort max --permission-mode bypassPermissions'\nalias o='codex --dangerously-bypass-approvals-and-sandbox'\nalias ga='git add' gc='git commit -v' gl='git pull' gp='git push' gg='lazygit' gst='git status' gco='git checkout'\nalias gr='git restore' grs='git restore --staged' gd='git diff' gds='git diff --staged' glog='git log --all --decorate --oneline --graph'\nalias ls='eza' l='eza -lbF --git' ll='eza -la --git' tree='eza --tree --git' ltree='tree -l'\nalias cat='bat'\nalias vi=\"nvim\" vim=\"vi\"\nalias y='pbcopy' p='pbpaste'\nalias rr='source ~/.zshrc'\nalias rm='echo \"rm is disabled. use `trash` command instead.\"'\nalias -g ...='../..'\nalias -g ....='../../..'\n\nsetopt append_history\nsetopt autopushd\nsetopt extended_glob\nsetopt hist_find_no_dups\nsetopt hist_ignore_all_dups\nsetopt hist_ignore_space\nsetopt hist_reduce_blanks\nsetopt hist_save_no_dups\nsetopt inc_append_history\nsetopt interactive_comments\nsetopt share_history\n\nbindkey -e\nbindkey '^[[1;3C' forward-word\nbindkey '^[[1;3D' backward-word\nbindkey '^[[1;5C' end-of-line\nbindkey '^[[1;5D' beginning-of-line\nbindkey '^[b' beginning-of-line\nbindkey '^[f' end-of-line\n\nsource \u003c(fzf --zsh)\nsource ~/.zsh/alias-tips/alias-tips.plugin.zsh\n\ntmp() {\n  TMP=~/tmp/$(date +%F)\n  if [ \"$#\" -gt 0 ]; then\n    TMP=\"${TMP}-$(echo \"$@\" | tr ' ' '-')\"\n  fi\n  mkdir -p \"$TMP\"\n  cd \"$TMP\"\n}\n\neval \"$(starship init zsh)\"\neval \"$(zoxide init zsh)\"",
            "id": "~/.zshrc.preview",
            "path": "~/.zshrc.preview"
          },
          "sensitive_attributes": [],
          "identity_schema_version": 0
        }
      ]
    },
