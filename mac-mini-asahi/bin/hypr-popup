#!/usr/bin/env bash
set -euo pipefail

browser="${BROWSER:-chromium-browser}"
class="${POPUP_CLASS:-popup-default}"
mobile=0
reuse=1
size="430,740"
pos="20,40"
use_x11=1
UA_MOBILE_DEFAULT='Mozilla/5.0 (Linux; Android 14; Pixel 8) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Mobile Safari/537.36'
uach_off=0
touch=0
scale=""
restart=0

while [[ $# -gt 0 ]]; do
  case "$1" in
    --class) class="$2"; shift 2;;
    --mobile) mobile=1; shift;;
    --desktop) mobile=0; shift;;
    --reuse) reuse=1; shift;;
    --no-reuse) reuse=0; shift;;
    --size) size="$2"; shift 2;;   # "W,H"
    --pos) pos="$2"; shift 2;;     # "X,Y"
    --wayland) use_x11=0; shift;;
    --x11) use_x11=1; shift;;
    --uach-off) uach_off=1; shift;;
    --touch) touch=1; shift;;
    --ua) UA_MOBILE_DEFAULT="$2"; shift 2;;
    --scale) scale="$2"; shift 2;;
    --restart) restart=1; shift;;
    *) break;;
  esac
done

url=""
if [[ -t 0 ]]; then
  url="${1:-}"
else
  url="$(cat)"
fi

url="$(printf '%s' "$url" | tr '\n' ' ' | sed -E 's/[[:space:]]+/ /g; s/^ +| +$//g')"
[[ -n "$url" ]] || exit 0

profile="${XDG_STATE_HOME:-$HOME/.local/state}/hypr-popup/${class}"
mkdir -p "$profile"

if (( reuse )) && (( restart )); then
  addr="$(hyprctl -j clients | jq -r --arg c "$class" '.[] | select(.class==$c) | .address' | head -n1 || true)"
  if [[ -n "${addr:-}" ]]; then
    hyprctl dispatch closewindow "address:$addr" >/dev/null 2>&1 || true
    sleep 0.05
  fi
fi

if (( reuse )); then
  addr="$(hyprctl -j clients | jq -r --arg c "$class" '.[] | select(.class==$c) | .address' | head -n1 || true)"
  if [[ -n "${addr:-}" ]] && command -v wtype >/dev/null 2>&1; then
    hyprctl dispatch focuswindow "address:$addr" >/dev/null 2>&1 || true
    sleep 0.05
    wtype -M ctrl l -m ctrl
    wtype "$url"
    wtype -k return
    exit 0
  fi
fi

args=(
  "--class=$class"
  "--user-data-dir=$profile"
  "--app=$url"
  "--window-size=$size"
  "--window-position=$pos"
)

if (( mobile )); then
  args+=("--user-agent=$UA_MOBILE_DEFAULT")
  args+=("--disable-features=UserAgentClientHint")
fi

if (( use_x11 )); then
  args+=("--ozone-platform=x11")
fi

if [[ -n "${scale:-}" ]]; then
  args+=("--force-device-scale-factor=$scale")
fi

exec "$browser" "${args[@]}" >/dev/null 2>&1 &
