#!/usr/bin/env bash
set -euo pipefail

runtime="${XDG_RUNTIME_DIR:-/run/user/$(id -u)}"
target_file="$runtime/hypr-hotkey-target"

if [[ -f "$target_file" ]]; then
  target="$(cat "$target_file" 2>/dev/null || true)"
  if [[ -n "${target:-}" ]]; then
    if hyprctl -j clients | jq -e --arg addr "$target" '.[] | select(.address == $addr)' >/dev/null 2>&1; then
      printf '%s\n' "$target"
      exit 0
    else
      rm -f "$target_file" 2>/dev/null || true
    fi
  fi
fi

addr="$(
  hyprctl -j clients | jq -r '
    [ .[]
      | select((.class|ascii_downcase) | test("chrom(e|ium)"))
      | {address, focusHistoryID}
    ]
    | sort_by(.focusHistoryID)
    | last
    | .address // empty
  '
)"

[[ -n "${addr:-}" ]] || exit 1
printf '%s\n' "$addr"
